# Copy to config.toml and set your sandbox/production token.
# config.toml is gitignored.

[api]
base_url = "https://sandbox.superfrete.com/api/v0"
token = "REPLACE_ME"
user_agent = "SuperFrete Quote CLI/0.1.0 (you@example.com)"

[quote]
from_postal_code = "08538300"
# Comma-separated SuperFrete service codes. One CSV row per service per destination.
# 1=PAC, 2=SEDEX, 17=Mini Envios, 3=Jadlog, 31=Loggi
services = "31"
use_insurance_value = true
max_insurance_value_brl = 3000.0
# Used for Fixed Wireless insurance USD→BRL and for CSV BRL→USD when output_currency = "USD"
usd_brl_rate = 5.50
output_currency = "BRL"  # "BRL" | "USD"

[[products]]
key = "managed"
label = "Managed  (41.84 lb / 18.98 kg)"
length_cm = 73
width_cm = 50
height_cm = 26
weight_kg = 18.98
insurance_value_brl = 3000.0

[[products]]
key = "light"
label = "Light  (35.41 lb / 16.06 kg)"
length_cm = 73
width_cm = 50
height_cm = 22
weight_kg = 16.06
insurance_value_brl = 3000.0

[[products]]
key = "fixed_wireless"
label = "Fixed Wireless  (6.83 lb / 3.10 kg)"
length_cm = 30
width_cm = 22
height_cm = 18
weight_kg = 3.10
insurance_value_usd = 350.0

